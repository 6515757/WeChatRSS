# 数据库
DATABASE_PATH=./data/wechat-rss.db

# LLM 配置
LLM_API_KEY=sk-wESImmISAMh7nl1fCDr7sYI0ql2J0l6G1f7RhJoahLBWhDcc
LLM_BASE_URL=https://api.ikuncode.cc/v1
LLM_MODEL=claude-sonnet-4-6

# 服务配置
PORT=3000
HOST=0.0.0.0

# 定时任务 Cron 表达式
# 抓取任务：每天 8:00 和 18:00
FETCH_CRON=0 8,18 * * *
# 分析任务：每天 8:30 和 18:30
ANALYZE_CRON=30 8,18 * * *
# 日报生成：每天 20:00
DAILY_REPORT_CRON=0 20 * * *

# LLM 并发控制（同时最多几个请求）
LLM_CONCURRENCY=3

# we-mp-rss 服务地址（Docker 启动后填写）
WE_MP_RSS_URL=http://localhost:8001
